// Persistence layer (roadmap step 2). SQLite (ADR-002): the file is the backup.
// Enums and scalar lists are unsupported on SQLite, so `type`/`status` are
// plain strings (constrained by the domain) and list/JSON fields use `Json`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model SourceType {
  id        String   @id @default(cuid())
  name      String // stored as entered
  nameKey   String   @unique // lowercased name — case-insensitive dedup ("livro" == "Livro")
  createdAt DateTime @default(now())
  sources   Source[]
}

model Source {
  id           String         @id @default(cuid())
  name         String
  url          String?        @unique // unique only when present (book has none)
  sourceType   SourceType     @relation(fields: [sourceTypeId], references: [id])
  sourceTypeId String
  createdAt    DateTime       @default(now())
  sightings    WordSighting[]
  exams        Exam[]
}

model Word {
  id            String         @id @default(cuid())
  term          String // stored as entered
  termKey       String         @unique // lowercased term — case-insensitive dedup, never lemmatised
  kind          String         @default("palavra") // 'palavra' | 'expressao' (ADR-005) — discriminates words from fixed expressions
  definitionEn  String
  definitionPt  String
  examples      String // JSON-encoded string[] of authorial sentences (SQLite has no Json/array type)
  observations  String         @default("[]") // JSON-encoded string[] of student-added context
  // SRS fields (§6 / §6.1). State is derived, never stored.
  easeFactor    Float          @default(2.5)
  intervalDays  Int            @default(0)
  repetitions   Int            @default(0)
  nextReview    DateTime
  createdAt     DateTime       @default(now())
  sightings     WordSighting[]
  reviewLogs    ReviewLog[]
  examWords     ExamWord[]
  examQuestions ExamQuestion[]
}

model WordSighting {
  id               String   @id @default(cuid())
  word             Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)
  wordId           String
  source           Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceId         String
  seenAt           DateTime @default(now())
  contextSentence  String? // the real sentence from the source (optional)
  isFirstEncounter Boolean // word registered here vs. re-encountered
  // Optional per-source meaning, separate from the word's general definition.
  definitionEn     String?
  definitionPt     String?
  examples         String? // JSON-encoded string[] of examples specific to this source

  @@index([wordId])
  @@index([sourceId])
}

model ReviewLog {
  id           String   @id @default(cuid())
  word         Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)
  wordId       String
  quality      Int // 0..5
  reviewedAt   DateTime @default(now())
  intervalDays Int // snapshot of the resulting interval

  @@index([wordId])
}

model Exam {
  id               String         @id @default(cuid())
  type             String // 'semanal' | 'vocabulario' | 'compreensao' | 'pratica'
  source           Source?        @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  sourceId         String?
  status           String // quiz: 'em_andamento' | 'finalizada' — legacy/comprehension: 'gerada' | 'respondida' | 'corrigida'
  promptText       String
  answersText      String? // the exam + answers, pasted back
  correctionPrompt String? // the generated correction prompt
  resultJson       String? // JSON-encoded validated ExamResult (SQLite has no Json type)
  score            Int?
  finishedAt       DateTime? // when a quiz was closed (quiz flow only)
  // Practice quizzes re-test the mistakes of a finished exam; the link survives
  // deletion of the origin exam (SetNull) so the practice stays readable.
  practiceOf       Exam?          @relation("PracticeOf", fields: [practiceOfId], references: [id], onDelete: SetNull)
  practiceOfId     String?
  practices        Exam[]         @relation("PracticeOf")
  createdAt        DateTime       @default(now())
  examWords        ExamWord[]
  questions        ExamQuestion[]
}

model ExamQuestion {
  id                 String    @id @default(cuid())
  exam               Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  examId             String
  word               Word      @relation(fields: [wordId], references: [id], onDelete: Cascade)
  wordId             String
  position           Int
  type               String // 'mc_en_pt' | 'mc_pt_en' | 'typed' | 'cloze' | 'ai_context'
  prompt             String
  options            String? // JSON-encoded string[] of choices (SQLite has no array type)
  correctIndex       Int? // multiple choice only
  correctAnswer      String? // typed/cloze only
  contextSentence    String? // the source sentence backing a cloze/ai question
  explanation        String? // short PT explanation of the correct answer (AI-generated)
  optionExplanations String? // JSON-encoded string[] aligned with options; null on legacy questions
  userAnswer         String?
  isCorrect          Boolean?
  answeredAt         DateTime?

  // One question per word per exam keeps ExamWord's uniqueness invariant.
  @@unique([examId, position])
  @@unique([examId, wordId])
  @@index([wordId])
}

model ExamWord {
  id      String  @id @default(cuid())
  exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  examId  String
  word    Word    @relation(fields: [wordId], references: [id], onDelete: Cascade)
  wordId  String
  correct Boolean

  @@unique([examId, wordId])
  @@index([wordId])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
