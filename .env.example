# Local SQLite database (the file IS the backup — ADR-002).
DATABASE_URL="file:./dev.db"

# Port for `npm run dev` / `npm run start`. Leave unset for the default 3000.
# PORT=3000

# Optional — AI via API (ADR-001). Leave unset for the default Manual mode
# (copy-paste, zero cost). Set the key to enable the opt-in ApiAdapter.
# ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_MODEL="claude-opus-4-8"   # default; set claude-sonnet-4-6 for a cheaper tier
